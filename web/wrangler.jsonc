{
  "name": "kwik",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-16",
  "compatibility_flags": ["nodejs_compat"],

  "routes": [
    {
      "pattern": "kwik.se",
      "custom_domain": true,
    },
  ],

  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "ratelimits": [
    {
      "name": "PUBLIC",
      "namespace_id": "1",
      "simple": {
        "limit": 60,
        "period": 60,
      },
    },
  ],
}
